[core]
  editor = nvim -u NONE -U NONE -N -i NONE
  pager = delta
  autocrlf = false
  quotepath = false
  commitEncoding = utf-8
  logOutputEncoding = utf-8
[filter "lfs"]
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
[user]
  name = Jonas Gao
  email = gaopinsong@live.cn
[alias]
  # 提交相关
  cam = commit -a -m
  cm = commit -m
  ca = commit -a
  amend = commit --amend
  amen = commit --amend --no-edit
  
  # 分支相关
  c = checkout
  co = checkout
  cob = checkout -b
  b = branch
  br = branch
  bd = branch -d
  bD = branch -D
  
  # 拉取推送
  pr = pull -r
  p = push
  pf = push --force-with-lease
  pl = pull
  f = fetch
  fa = fetch --all
  
  # 状态和差异
  st = status
  s = status -s
  d = diff
  dc = diff --cached
  ds = diff --stat
  
  # 日志查看
  lg = log --graph --oneline --decorate --all
  ll = log --pretty=format:'%C(yellow)%h%Cred%d %Creset%s%Cblue [%cn]' --decorate
  ls = log --pretty=format:'%C(yellow)%h %C(cyan)%ad %Cred%d %Creset%s%Cblue [%cn]' --decorate --date=short
  last = log -1 HEAD
  
  # 撤销相关
  unstage = reset HEAD --
  undo = reset --soft HEAD~1
  discard = checkout --
  
  # Stash 相关
  sl = stash list
  sp = stash pop
  ss = stash save
  
  # Worktree 相关
  wt = worktree                    # worktree 子命令（默认输出帮助）
  wtl = worktree list              # 列出工作树
  wta = worktree add               # 添加工作树
  wtr = worktree remove            # 移除工作树
  wtp = worktree prune             # 清理失效登记
  wtm = worktree move              # 移动工作树目录
  wtlk = worktree lock             # 锁定工作树（避免被 prune）
  wtul = worktree unlock           # 解锁工作树
  
  # 其他实用别名
  aliases = config --get-regexp alias
  contributors = shortlog --summary --numbered
  tags = tag -l
  remotes = remote -v
  [interactive]
	diffFilter = delta --color-only --features=interactive
[delta]
	features = decorations
	side-by-side = true
	line-numbers = true
[delta "interactive"]
	keep-plus-minus-markers = false
[delta "decorations"]
	commit-decoration-style = blue ol
	commit-style = raw
	file-style = omit
	hunk-header-decoration-style = blue box
	hunk-header-file-style = red
	hunk-header-line-number-style = "#067a00"
	hunk-header-style = file line-number syntax
[http "https://github.com"]
	proxy = http://xx.my:7890
[http "https://huggingface.co"]
	proxy = http://xx.my:7890
[credential "https://codeup.aliyun.com"]
	provider = generic
[init]
	defaultBranch = main
